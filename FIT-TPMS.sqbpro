anh sách báo cáo đã đăng lên web
CREATE VIEW view_published_reports AS
SELECT 
    pr.id AS report_id,
    t.title,
    t.description AS abstract,
    pr.file_url,
    pr.source_code_url,
    pr.published_at,
    s.student_code,
    u.full_name AS student_name,
    u2.full_name AS lecturer_name,
    ct.type_name AS course_type,
    sem.name AS semester,
    sem.year
FROM published_reports pr
JOIN topics t ON pr.topic_id = t.id
JOIN students s ON pr.student_id = s.id
JOIN users u ON s.user_id = u.id
JOIN classes c ON pr.class_id = c.id
JOIN lecturers l ON c.lecturer_id = l.id
JOIN users u2 ON l.user_id = u2.id
JOIN courses cr ON c.course_id = cr.id
JOIN course_types ct ON cr.course_type_id = ct.id
JOIN semesters sem ON c.semester_id = sem.id
ORDER BY pr.published_at DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
